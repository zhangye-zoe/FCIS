# ------------------------------------------------------------
.DS_Store
.vscode/
__vscode__/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# Python cache / build files
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------
# Logs / temporary files
# ------------------------------------------------------------
*.log
*.log.*
*.json
*.npz
*.p
try.*
setup2.py
setup2.cfg

# ------------------------------------------------------------
# Model checkpoints / training outputs
# ------------------------------------------------------------
*.pth
checkpoints/
work_dirs*/
collect*/
zy_fcis_pannuke/

# ------------------------------------------------------------
# Data files
# ------------------------------------------------------------
*.npy
*.png
*.jpg
*.jpeg
*.tif
*.tiff

# ------------------------------------------------------------
# Datasets
# ------------------------------------------------------------
data/DSB2018/
data/PanNuke/
data/Yeaz/
# data/BBBC006/

# Dataset symbolic link
# /data

# ------------------------------------------------------------
# Project-specific generated folders
# ------------------------------------------------------------
configs2/
z_visual/
visualization/
.*_show

# ------------------------------------------------------------
# Config files not intended for release
# ------------------------------------------------------------
configs/FCIS/unet_pannuke.py

# ------------------------------------------------------------
# Jupyter files
# ------------------------------------------------------------
.ipynb_checkpoints/
.ipynb_checkpoint/
preprocessing/pannuke_processing.ipynb

# ------------------------------------------------------------
# Compressed files
# ------------------------------------------------------------
*.zip
*.rar
*.tar
*.tar.gz
*.tgz
*.7z

# ------------------------------------------------------------
